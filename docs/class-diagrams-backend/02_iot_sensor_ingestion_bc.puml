@startuml 02_IoTSensorIngestionBC
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam linetype ortho

title SpotTrack — BC 2: IoT Sensor Ingestion\n(Tabla: iot_devices · sensor_readings · device_calibrations)

package "IoT Sensor Ingestion BC" #FFF8E1 {

  ' ── Enums ──────────────────────────────────────────
  enum SensorType {
    CAMERA
    MOTION
    WEIGHT
  }

  enum DeviceStatus {
    ONLINE
    OFFLINE
    CALIBRATING
    LOW_BATTERY
  }

  ' ── Value Objects ───────────────────────────────────
  class MacAddress <<ValueObject>> {
    + value: String
    + validate(): boolean
  }

  class CalibrationParameter <<ValueObject>> {
    + pingIntervalSeconds: int
    + batteryThresholdPercent: int
    + gracePeriodSeconds: int
    + rackWeightOffsetKg: double
  }

  class SensorData <<ValueObject>> {
    + rawValue: double
    + unit: String
    + normalizedValue: double
    --
    + normalize(): SensorData
  }

  ' ── Aggregate Root ──────────────────────────────────
  class IoTDevice <<AggregateRoot>> {
    + deviceId: UUID
    + macAddress: MacAddress
    + firmwareVersion: String
    + status: DeviceStatus
    + sensorType: SensorType
    + lastHeartbeat: LocalDateTime
    + batteryLevel: int
    --
    + calibrate(params: CalibrationParameter): DeviceCalibratedEvent
    + emitReading(data: SensorData): SensorDataCapturedEvent
    + checkBattery(): void
    + goOffline(): SensorOfflineEvent
  }

  ' ── Entities ────────────────────────────────────────
  class SensorReading <<Entity>> {
    + readingId: UUID
    + deviceId: UUID
    + data: SensorData
    + capturedAt: LocalDateTime
    --
    + isValid(): boolean
  }

  class DeviceCalibration <<Entity>> {
    + calibrationId: UUID
    + deviceId: UUID
    + parameters: CalibrationParameter
    + calibratedBy: UUID
    + calibratedAt: LocalDateTime
  }

  ' ── Domain Events ───────────────────────────────────
  class SensorDataCapturedEvent <<DomainEvent>> {
    + deviceId: UUID
    + sensorType: SensorType
    + data: SensorData
  }

  class DeviceCalibratedEvent <<DomainEvent>> {
    + deviceId: UUID
    + parameters: CalibrationParameter
  }

  class SensorOfflineEvent <<DomainEvent>> {
    + deviceId: UUID
    + lastHeartbeat: LocalDateTime
  }

  class LowBatteryAlertEvent <<DomainEvent>> {
    + deviceId: UUID
    + batteryLevel: int
  }

  ' ── Repositories ────────────────────────────────────
  interface IoTDeviceRepository <<Repository>> {
    + findByMacAddress(mac: String): Optional<IoTDevice>
    + findByStatus(status: DeviceStatus): List<IoTDevice>
    + findBySensorType(type: SensorType): List<IoTDevice>
  }

  interface SensorReadingRepository <<Repository>> {
    + findByDeviceId(id: UUID): List<SensorReading>
    + findByDeviceIdAndDateRange(id: UUID, start: LocalDateTime, end: LocalDateTime): List<SensorReading>
  }

  ' ── Application Service ─────────────────────────────
  class IoTIngestionApplicationService <<ApplicationService>> {
    - deviceRepo: IoTDeviceRepository
    - readingRepo: SensorReadingRepository
    - publisher: DomainEventPublisher
    --
    + ingestReading(cmd: IngestReadingCommand): void
    + calibrateDevice(cmd: CalibrateDeviceCommand): void
    + calibrateRackWeight(cmd: CalibrateRackWeightCommand): void
    + setPingInterval(cmd: SetPingIntervalCommand): void
    + setBatteryThreshold(cmd: SetBatteryThresholdCommand): void
    + setGracePeriod(cmd: SetGracePeriodCommand): void
  }

  ' ── Relaciones ──────────────────────────────────────
  IoTDevice *-- MacAddress
  IoTDevice *-- CalibrationParameter
  IoTDevice -- SensorType
  IoTDevice -- DeviceStatus
  IoTDevice "1" *-- "*" SensorReading
  IoTDevice "1" *-- "*" DeviceCalibration
  SensorReading *-- SensorData
  DeviceCalibration *-- CalibrationParameter

  IoTDevice ..> SensorDataCapturedEvent : publishes
  IoTDevice ..> DeviceCalibratedEvent : publishes
  IoTDevice ..> SensorOfflineEvent : publishes
  IoTDevice ..> LowBatteryAlertEvent : publishes

  IoTIngestionApplicationService --> IoTDeviceRepository
  IoTIngestionApplicationService --> SensorReadingRepository
}

note bottom of SensorDataCapturedEvent
  Este evento es consumido por
  el Monitoring BC
end note
@enduml
