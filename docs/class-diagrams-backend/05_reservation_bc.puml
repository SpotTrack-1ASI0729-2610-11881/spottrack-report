@startuml 05_ReservationBC
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam linetype ortho

title SpotTrack — BC 5: Reservation\n(Tabla: reservations · availability_alerts · reservation_timers)

package "Reservation BC" #E0F2F1 {

  ' ── Enums ──────────────────────────────────────────
  enum ReservationStatus {
    PENDING
    CONFIRMED
    CANCELLED
    EXPIRED
    OCCUPIED
  }

  ' ── Value Objects ───────────────────────────────────
  class ReservationSlot <<ValueObject>> {
    + equipmentId: UUID
    + scheduledAt: LocalDateTime
    + durationMinutes: int
    --
    + isAvailable(): boolean
  }

  ' ── Aggregate Root ──────────────────────────────────
  class Reservation <<AggregateRoot>> {
    + reservationId: UUID
    + clientId: UUID
    + slot: ReservationSlot
    + status: ReservationStatus
    --
    + initiateExpress(): ExpressReservationInitiatedEvent
    + confirmOccupation(): EquipmentBecameOccupiedEvent
    + cancel(): ReservationCancelledEvent
    + expire(): ReservationTimerExpiredEvent
    + requestAlternative(): AlternativeEquipmentRequestedEvent
  }

  ' ── Entities ────────────────────────────────────────
  class AvailabilityAlert <<Entity>> {
    + alertId: UUID
    + clientId: UUID
    + equipmentId: UUID
    + subscribedAt: LocalDateTime
    + expired: boolean
    --
    + trigger(): AvailabilityAlertTriggeredEvent
    + expire(): AvailabilityAlertExpiredEvent
  }

  class ReservationTimer <<Entity>> {
    + timerId: UUID
    + reservationId: UUID
    + expiresAt: LocalDateTime
    + expired: boolean
    --
    + isExpired(): boolean
    + cancel(): void
  }

  ' ── Domain Events ───────────────────────────────────
  class ExpressReservationInitiatedEvent <<DomainEvent>> {
    + reservationId: UUID
    + clientId: UUID
    + equipmentId: UUID
  }

  class ReservationCancelledEvent <<DomainEvent>> {
    + reservationId: UUID
    + reason: String
  }

  class ReservationTimerExpiredEvent <<DomainEvent>> {
    + reservationId: UUID
    + equipmentId: UUID
  }

  class EquipmentBecameOccupiedEvent <<DomainEvent>> {
    + reservationId: UUID
    + equipmentId: UUID
    + clientId: UUID
  }

  class AvailabilityAlertTriggeredEvent <<DomainEvent>> {
    + alertId: UUID
    + clientId: UUID
    + equipmentId: UUID
  }

  class AvailabilityAlertExpiredEvent <<DomainEvent>> {
    + alertId: UUID
  }

  class AlternativeEquipmentRequestedEvent <<DomainEvent>> {
    + reservationId: UUID
    + originalEquipmentId: UUID
  }

  ' ── Repositories ────────────────────────────────────
  interface ReservationRepository <<Repository>> {
    + findByClientId(clientId: UUID): List<Reservation>
    + findByEquipmentId(id: UUID): List<Reservation>
    + findActiveByEquipmentId(id: UUID): Optional<Reservation>
    + findByStatus(status: ReservationStatus): List<Reservation>
  }

  interface AvailabilityAlertRepository <<Repository>> {
    + findByEquipmentId(id: UUID): List<AvailabilityAlert>
    + findActiveByClientId(clientId: UUID): List<AvailabilityAlert>
  }

  ' ── Application Service ─────────────────────────────
  class ReservationApplicationService <<ApplicationService>> {
    - reservationRepo: ReservationRepository
    - alertRepo: AvailabilityAlertRepository
    - publisher: DomainEventPublisher
    --
    + initiateExpressReservation(cmd: InitiateReservationCommand): Reservation
    + cancelReservation(cmd: CancelReservationCommand): void
    + subscribeToAvailabilityAlert(cmd: SubscribeAlertCommand): AvailabilityAlert
    + requestAlternativeEquipment(cmd: AlternativeEquipmentCommand): void
    + handleEquipmentStatusUpdated(event: EquipmentStatusUpdatedEvent): void
    + handleMembershipSuspended(event: MembershipSuspendedEvent): void
  }

  ' ── Relaciones ──────────────────────────────────────
  Reservation *-- ReservationSlot
  Reservation "1" *-- "1" ReservationTimer
  Reservation -- ReservationStatus

  Reservation ..> ExpressReservationInitiatedEvent : publishes
  Reservation ..> ReservationCancelledEvent : publishes
  Reservation ..> ReservationTimerExpiredEvent : publishes
  Reservation ..> EquipmentBecameOccupiedEvent : publishes
  Reservation ..> AlternativeEquipmentRequestedEvent : publishes
  AvailabilityAlert ..> AvailabilityAlertTriggeredEvent : publishes
  AvailabilityAlert ..> AvailabilityAlertExpiredEvent : publishes

  ReservationApplicationService --> ReservationRepository
  ReservationApplicationService --> AvailabilityAlertRepository
}

note top of ReservationApplicationService
  Consume: EquipmentStatusUpdatedEvent (desde Equipment BC)
  Consume: MembershipSuspendedEvent (desde Membership BC)
end note
@enduml
