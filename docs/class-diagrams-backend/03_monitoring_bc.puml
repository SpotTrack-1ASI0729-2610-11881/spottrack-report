@startuml 03_MonitoringBC
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam linetype ortho

title SpotTrack — BC 3: Monitoring\n(Tabla: monitoring_sessions · occupancy_records · equipment_anomalies · heatmap_snapshots)

package "Monitoring BC" #FFF3E0 {

  ' ── Enums ──────────────────────────────────────────
  enum SessionStatus {
    STARTED
    ACTIVE
    ENDED
  }

  enum AnomalyType {
    EQUIPMENT_MISPLACED
    STATIC_MISPLACED
    DYNAMIC_MISPLACED
    THRESHOLD_EXCEEDED
  }

  ' ── Value Objects ───────────────────────────────────
  class OccupancySignal <<ValueObject>> {
    + equipmentId: UUID
    + isOccupied: boolean
    + confirmedByCamera: boolean
    + detectedAt: LocalDateTime
  }

  class MaintenanceThreshold <<ValueObject>> {
    + metricName: String
    + thresholdValue: double
    + unit: String
    --
    + isExceeded(currentValue: double): boolean
  }

  ' ── Aggregate Root ──────────────────────────────────
  class MonitoringSession <<AggregateRoot>> {
    + sessionId: UUID
    + equipmentId: UUID
    + clientId: UUID
    + status: SessionStatus
    + startedAt: LocalDateTime
    + endedAt: LocalDateTime
    --
    + start(): UsageSessionStartedEvent
    + end(): UsageSessionEndedEvent
    + duration(): Duration
  }

  ' ── Entities ────────────────────────────────────────
  class OccupancyRecord <<Entity>> {
    + recordId: UUID
    + equipmentId: UUID
    + signal: OccupancySignal
    + recordedAt: LocalDateTime
    --
    + isValidOccupancy(): boolean
  }

  class EquipmentAnomaly <<Entity>> {
    + anomalyId: UUID
    + equipmentId: UUID
    + anomalyType: AnomalyType
    + detectedAt: LocalDateTime
    + validated: boolean
    --
    + validate(): AnomalyDetectedEvent
    + triggerMaintenanceRequest(): MaintenanceRequestedEvent
  }

  class HeatmapSnapshot <<Entity>> {
    + snapshotId: UUID
    + branchId: UUID
    + data: Map<UUID,Integer>
    + capturedAt: LocalDateTime
    + thresholdExceeded: boolean
    --
    + update(signal: OccupancySignal): HeatmapUpdatedEvent
  }

  ' ── Domain Events ───────────────────────────────────
  class UsageSessionStartedEvent <<DomainEvent>> {
    + sessionId: UUID
    + equipmentId: UUID
    + clientId: UUID
  }

  class UsageSessionEndedEvent <<DomainEvent>> {
    + sessionId: UUID
    + durationMinutes: double
  }

  class AnomalyDetectedEvent <<DomainEvent>> {
    + anomalyId: UUID
    + equipmentId: UUID
    + anomalyType: AnomalyType
  }

  class MaintenanceRequestedEvent <<DomainEvent>> {
    + equipmentId: UUID
    + reason: String
    + anomalyId: UUID
  }

  class HeatmapUpdatedEvent <<DomainEvent>> {
    + snapshotId: UUID
    + branchId: UUID
    + highDemandDetected: boolean
  }

  ' ── Repositories ────────────────────────────────────
  interface MonitoringSessionRepository <<Repository>> {
    + findActiveByEquipmentId(id: UUID): Optional<MonitoringSession>
    + findByClientId(clientId: UUID): List<MonitoringSession>
    + findByDateRange(start: LocalDateTime, end: LocalDateTime): List<MonitoringSession>
  }

  interface EquipmentAnomalyRepository <<Repository>> {
    + findByEquipmentId(id: UUID): List<EquipmentAnomaly>
    + findUnvalidated(): List<EquipmentAnomaly>
  }

  interface HeatmapSnapshotRepository <<Repository>> {
    + findLatestByBranchId(branchId: UUID): Optional<HeatmapSnapshot>
  }

  ' ── Application Service ─────────────────────────────
  class MonitoringApplicationService <<ApplicationService>> {
    - sessionRepo: MonitoringSessionRepository
    - anomalyRepo: EquipmentAnomalyRepository
    - heatmapRepo: HeatmapSnapshotRepository
    - publisher: DomainEventPublisher
    --
    + handleSensorDataCaptured(event: SensorDataCapturedEvent): void
    + startUsageSession(cmd: StartSessionCommand): MonitoringSession
    + endUsageSession(cmd: EndSessionCommand): void
    + reportAnomalyManually(cmd: ReportAnomalyCommand): void
    + updateThreshold(cmd: UpdateThresholdCommand): void
    + getEquipmentStatus(equipmentId: UUID): OccupancySignal
  }

  ' ── Relaciones ──────────────────────────────────────
  MonitoringSession -- SessionStatus
  MonitoringSession *-- OccupancySignal
  EquipmentAnomaly -- AnomalyType
  OccupancyRecord *-- OccupancySignal
  HeatmapSnapshot *-- OccupancySignal

  MonitoringSession ..> UsageSessionStartedEvent : publishes
  MonitoringSession ..> UsageSessionEndedEvent : publishes
  EquipmentAnomaly ..> AnomalyDetectedEvent : publishes
  EquipmentAnomaly ..> MaintenanceRequestedEvent : publishes
  HeatmapSnapshot ..> HeatmapUpdatedEvent : publishes

  MonitoringApplicationService --> MonitoringSessionRepository
  MonitoringApplicationService --> EquipmentAnomalyRepository
  MonitoringApplicationService --> HeatmapSnapshotRepository
}

note top of MonitoringApplicationService
  Consume: SensorDataCapturedEvent (desde IoT BC)
  Publica: MaintenanceRequestedEvent → Maintenance BC
  Publica: UsageSessionEndedEvent → Analytics BC
end note
@enduml
