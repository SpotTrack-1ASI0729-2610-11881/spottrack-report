@startuml 00_SharedKernel
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam linetype ortho

title SpotTrack — Shared Kernel\n(Value Objects y tipos base reutilizados por todos los Bounded Contexts)

package "Shared Kernel" #EEF2FF {

  class AuditableEntity <<abstract>> {
    # createdAt: LocalDateTime
    # updatedAt: LocalDateTime
    # createdBy: String
  }

  class Money <<ValueObject>> {
    + amount: BigDecimal
    + currency: String
    + add(other: Money): Money
    + subtract(other: Money): Money
  }

  class DateRange <<ValueObject>> {
    + startDate: LocalDate
    + endDate: LocalDate
    + isActive(): boolean
    + overlaps(other: DateRange): boolean
  }

  class EmailAddress <<ValueObject>> {
    + value: String
    + validate(): boolean
  }

  abstract class DomainEvent {
    + eventId: UUID
    + occurredOn: LocalDateTime
    + aggregateId: UUID
  }

  interface DomainEventPublisher {
    + publish(event: DomainEvent): void
  }

  interface Repository <<interface>> {
    + findById(id: UUID): Optional<T>
    + save(entity: T): T
    + delete(id: UUID): void
  }
}

note as N1
  Estos tipos son importados por
  todos los Bounded Contexts.
  No se repiten en cada diagrama.
end note
@enduml
