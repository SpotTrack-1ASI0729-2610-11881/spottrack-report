@startuml 04_EquipmentBC
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam linetype ortho

title SpotTrack — BC 4: Equipment\n(Tabla: equipment · equipment_racks · equipment_statuses · spare_parts)

package "Equipment BC" #E8F5E9 {

  ' ── Enums ──────────────────────────────────────────
  enum EquipmentType {
    STATIC
    DYNAMIC
  }

  enum EquipmentStatusType {
    AVAILABLE
    RESERVED
    IN_USE
    OUT_OF_SERVICE
    DECOMMISSIONED
    UNDER_MAINTENANCE
  }

  ' ── Value Objects ───────────────────────────────────
  class SerialNumber <<ValueObject>> {
    + value: String
    --
    + validate(): boolean
  }

  class RackPosition <<ValueObject>> {
    + rackId: UUID
    + slot: int
    + zone: String
  }

  ' ── Aggregate Root ──────────────────────────────────
  class Equipment <<AggregateRoot>> {
    + equipmentId: UUID
    + name: String
    + model: String
    + serialNumber: SerialNumber
    + equipmentType: EquipmentType
    + status: EquipmentStatusType
    + branchId: UUID
    + rackPosition: RackPosition
    --
    + register(): EquipmentRegisteredEvent
    + markOutOfService(): EquipmentMarkedOutOfServiceEvent
    + decommission(): EquipmentDecommissionedEvent
    + recommendTransfer(): EquipmentTransferRecommendedEvent
    + completeRelocation(): EquipmentRelocationCompletedEvent
    + updateStatus(s: EquipmentStatusType): EquipmentStatusUpdatedEvent
    + returnToRack(): StaticEquipmentReturnedToRackEvent
    + removeFromRack(): StaticEquipmentRemovedFromRackEvent
  }

  ' ── Entities ────────────────────────────────────────
  class EquipmentRack <<Entity>> {
    + rackId: UUID
    + branchId: UUID
    + capacity: int
    + currentWeight: double
    + calibratedAt: LocalDateTime
    --
    + addEquipment(eq: Equipment): void
    + removeEquipment(eq: Equipment): void
    + calibrateWeight(): RackWeightCalibratedEvent
  }

  class SparePart <<Entity>> {
    + sparePartId: UUID
    + name: String
    + partNumber: String
    + stockQuantity: int
    + minimumStock: int
    --
    + consume(qty: int): SparePartConsumedEvent
    + restock(qty: int): void
    + needsRestock(): boolean
  }

  ' ── Domain Events ───────────────────────────────────
  class EquipmentRegisteredEvent <<DomainEvent>> {
    + equipmentId: UUID
    + branchId: UUID
    + equipmentType: EquipmentType
  }

  class EquipmentStatusUpdatedEvent <<DomainEvent>> {
    + equipmentId: UUID
    + previousStatus: EquipmentStatusType
    + newStatus: EquipmentStatusType
  }

  class EquipmentMarkedOutOfServiceEvent <<DomainEvent>> {
    + equipmentId: UUID
    + reason: String
  }

  class EquipmentDecommissionedEvent <<DomainEvent>> {
    + equipmentId: UUID
  }

  class EquipmentTransferRecommendedEvent <<DomainEvent>> {
    + equipmentId: UUID
    + targetBranchId: UUID
  }

  class EquipmentRelocationCompletedEvent <<DomainEvent>> {
    + equipmentId: UUID
    + newBranchId: UUID
  }

  class SparePartConsumedEvent <<DomainEvent>> {
    + sparePartId: UUID
    + quantityConsumed: int
    + remainingStock: int
    + restockAlertTriggered: boolean
  }

  class RackWeightCalibratedEvent <<DomainEvent>> {
    + rackId: UUID
    + newOffsetKg: double
  }

  class StaticEquipmentRemovedFromRackEvent <<DomainEvent>> {
    + equipmentId: UUID
    + rackId: UUID
  }

  class StaticEquipmentReturnedToRackEvent <<DomainEvent>> {
    + equipmentId: UUID
    + rackId: UUID
  }

  ' ── Repositories ────────────────────────────────────
  interface EquipmentRepository <<Repository>> {
    + findByBranchId(branchId: UUID): List<Equipment>
    + findByStatus(status: EquipmentStatusType): List<Equipment>
    + findBySerialNumber(sn: String): Optional<Equipment>
    + searchByFilters(filters: EquipmentFilters): List<Equipment>
  }

  interface SparePartRepository <<Repository>> {
    + findByBranchId(branchId: UUID): List<SparePart>
    + findLowStock(): List<SparePart>
  }

  ' ── Application Service ─────────────────────────────
  class EquipmentApplicationService <<ApplicationService>> {
    - equipmentRepo: EquipmentRepository
    - sparePartRepo: SparePartRepository
    - publisher: DomainEventPublisher
    --
    + registerEquipment(cmd: RegisterEquipmentCommand): Equipment
    + searchEquipment(query: EquipmentSearchQuery): List<Equipment>
    + markOutOfService(cmd: MarkOutOfServiceCommand): void
    + decommissionEquipment(cmd: DecommissionCommand): void
    + recommendTransfer(cmd: RecommendTransferCommand): void
    + updateEquipmentStatus(cmd: UpdateStatusCommand): void
  }

  ' ── Relaciones ──────────────────────────────────────
  Equipment *-- SerialNumber
  Equipment *-- RackPosition
  Equipment -- EquipmentType
  Equipment -- EquipmentStatusType
  Equipment "1" --o "1" EquipmentRack

  Equipment ..> EquipmentRegisteredEvent : publishes
  Equipment ..> EquipmentStatusUpdatedEvent : publishes
  Equipment ..> EquipmentMarkedOutOfServiceEvent : publishes
  Equipment ..> EquipmentDecommissionedEvent : publishes
  Equipment ..> EquipmentTransferRecommendedEvent : publishes
  Equipment ..> EquipmentRelocationCompletedEvent : publishes
  Equipment ..> StaticEquipmentRemovedFromRackEvent : publishes
  Equipment ..> StaticEquipmentReturnedToRackEvent : publishes
  EquipmentRack ..> RackWeightCalibratedEvent : publishes
  SparePart ..> SparePartConsumedEvent : publishes

  EquipmentApplicationService --> EquipmentRepository
  EquipmentApplicationService --> SparePartRepository
}

note top of EquipmentApplicationService
  Publica: EquipmentStatusUpdatedEvent → Reservation BC
  Publica: EquipmentDecommissionedEvent → Reservation BC
  Publica: SparePartConsumedEvent → Analytics BC
end note
@enduml
