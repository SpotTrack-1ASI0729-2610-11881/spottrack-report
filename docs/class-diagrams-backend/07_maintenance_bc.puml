@startuml 07_MaintenanceBC
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam linetype ortho

title SpotTrack — BC 7: Maintenance\n(Tabla: technical_tickets · maintenance_jobs · spare_part_stocks · equipment_reports)

package "Maintenance BC" #FFEBEE {

  ' ── Enums ──────────────────────────────────────────
  enum TicketStatus {
    OPEN
    ASSIGNED
    ACCEPTED
    SCHEDULED
    IN_PROGRESS
    RESOLVED
    CLOSED
  }

  enum TicketPriority {
    LOW
    MEDIUM
    HIGH
    CRITICAL
  }

  enum JobStatus {
    PENDING
    ACCEPTED
    IN_PROGRESS
    COMPLETED
  }

  ' ── Value Objects ───────────────────────────────────
  class RepairDescription <<ValueObject>> {
    + description: String
    + rootCause: String
    + actionTaken: String
  }

  class MaintenanceCost <<ValueObject>> {
    + laborCost: Money
    + sparePartsCost: Money
    --
    + total(): Money
  }

  class Money <<ValueObject>> {
    + amount: BigDecimal
    + currency: String
    --
    + add(other: Money): Money
  }

  ' ── Aggregate Root ──────────────────────────────────
  class TechnicalTicket <<AggregateRoot>> {
    + ticketId: UUID
    + equipmentId: UUID
    + reportedBy: UUID
    + priority: TicketPriority
    + status: TicketStatus
    + description: String
    + createdAt: LocalDateTime
    + resolvedAt: LocalDateTime
    --
    + create(): TechnicalTicketCreatedEvent
    + assignTechnician(techId: UUID): TechnicalTicketAssignedEvent
    + accept(): MaintenanceJobAcceptedEvent
    + schedule(date: LocalDateTime): MaintenanceScheduledEvent
    + complete(desc: RepairDescription): MaintenanceCompletedEvent
    + markResolved(): TicketResolvedEvent
    + close(): void
  }

  ' ── Entities ────────────────────────────────────────
  class MaintenanceJob <<Entity>> {
    + jobId: UUID
    + ticketId: UUID
    + technicianId: UUID
    + status: JobStatus
    + scheduledAt: LocalDateTime
    + completedAt: LocalDateTime
    + cost: MaintenanceCost
    --
    + accept(): void
    + complete(cost: MaintenanceCost): void
  }

  class SparePartStock <<Entity>> {
    + sparePartId: UUID
    + name: String
    + partNumber: String
    + stockQuantity: int
    + minimumStock: int
    --
    + consume(qty: int): SparePartConsumedEvent
    + restock(qty: int): void
    + needsRestock(): boolean
  }

  class EquipmentReport <<Entity>> {
    + reportId: UUID
    + equipmentId: UUID
    + submittedBy: UUID
    + description: RepairDescription
    + submittedAt: LocalDateTime
    + validated: boolean
    --
    + validate(): ManualReportValidatedEvent
  }

  ' ── Domain Events ───────────────────────────────────
  class TechnicalTicketCreatedEvent <<DomainEvent>> {
    + ticketId: UUID
    + equipmentId: UUID
    + priority: TicketPriority
  }

  class TechnicalTicketAssignedEvent <<DomainEvent>> {
    + ticketId: UUID
    + technicianId: UUID
  }

  class MaintenanceJobAcceptedEvent <<DomainEvent>> {
    + jobId: UUID
    + technicianId: UUID
  }

  class MaintenanceScheduledEvent <<DomainEvent>> {
    + ticketId: UUID
    + scheduledAt: LocalDateTime
  }

  class MaintenanceCompletedEvent <<DomainEvent>> {
    + ticketId: UUID
    + equipmentId: UUID
    + cost: MaintenanceCost
  }

  class TicketResolvedEvent <<DomainEvent>> {
    + ticketId: UUID
    + resolvedAt: LocalDateTime
  }

  class SparePartConsumedEvent <<DomainEvent>> {
    + sparePartId: UUID
    + quantityConsumed: int
    + remainingStock: int
    + restockAlertTriggered: boolean
  }

  class ManualReportValidatedEvent <<DomainEvent>> {
    + reportId: UUID
    + equipmentId: UUID
  }

  ' ── Repositories ────────────────────────────────────
  interface TechnicalTicketRepository <<Repository>> {
    + findByEquipmentId(id: UUID): List<TechnicalTicket>
    + findByTechnicianId(id: UUID): List<TechnicalTicket>
    + findByStatus(status: TicketStatus): List<TechnicalTicket>
    + findOpenByPriority(priority: TicketPriority): List<TechnicalTicket>
  }

  interface SparePartStockRepository <<Repository>> {
    + findByBranchId(branchId: UUID): List<SparePartStock>
    + findLowStock(): List<SparePartStock>
  }

  interface EquipmentReportRepository <<Repository>> {
    + findByEquipmentId(id: UUID): List<EquipmentReport>
    + findPendingValidation(): List<EquipmentReport>
  }

  ' ── Application Service ─────────────────────────────
  class MaintenanceApplicationService <<ApplicationService>> {
    - ticketRepo: TechnicalTicketRepository
    - stockRepo: SparePartStockRepository
    - reportRepo: EquipmentReportRepository
    - publisher: DomainEventPublisher
    --
    + createTicket(cmd: CreateTicketCommand): TechnicalTicket
    + assignTicket(cmd: AssignTicketCommand): void
    + acceptMaintenanceJob(cmd: AcceptJobCommand): void
    + scheduleMaintenanceJob(cmd: ScheduleJobCommand): void
    + completeMaintenanceJob(cmd: CompleteJobCommand): void
    + consumeSparePart(cmd: ConsumeSparePartCommand): void
    + submitEquipmentReport(cmd: SubmitReportCommand): EquipmentReport
    + validateReport(cmd: ValidateReportCommand): void
    + handleMaintenanceRequested(event: MaintenanceRequestedEvent): void
  }

  ' ── Relaciones ──────────────────────────────────────
  TechnicalTicket -- TicketStatus
  TechnicalTicket -- TicketPriority
  TechnicalTicket "1" *-- "1" MaintenanceJob
  TechnicalTicket *-- RepairDescription
  MaintenanceJob -- JobStatus
  MaintenanceJob *-- MaintenanceCost
  MaintenanceCost *-- Money
  EquipmentReport *-- RepairDescription
  SparePartStock ..> SparePartConsumedEvent : publishes

  TechnicalTicket ..> TechnicalTicketCreatedEvent : publishes
  TechnicalTicket ..> TechnicalTicketAssignedEvent : publishes
  TechnicalTicket ..> MaintenanceJobAcceptedEvent : publishes
  TechnicalTicket ..> MaintenanceScheduledEvent : publishes
  TechnicalTicket ..> MaintenanceCompletedEvent : publishes
  TechnicalTicket ..> TicketResolvedEvent : publishes
  EquipmentReport ..> ManualReportValidatedEvent : publishes

  MaintenanceApplicationService --> TechnicalTicketRepository
  MaintenanceApplicationService --> SparePartStockRepository
  MaintenanceApplicationService --> EquipmentReportRepository
}

note top of MaintenanceApplicationService
  Consume: MaintenanceRequestedEvent (desde Monitoring BC)
  Publica: MaintenanceCompletedEvent → Equipment BC
  Publica: MaintenanceCompletedEvent → Analytics BC
  Publica: SparePartConsumedEvent → Analytics BC
end note
@enduml
