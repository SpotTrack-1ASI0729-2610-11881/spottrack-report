@startuml 08_AnalyticsBC
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam linetype ortho

title SpotTrack — BC 8: Analytics\n(Tabla: activity_reports · cost_reports · roi_reports)

package "Analytics BC" #E8EAF6 {

  ' ── Value Objects ───────────────────────────────────
  class DateRange <<ValueObject>> {
    + startDate: LocalDate
    + endDate: LocalDate
    --
    + isActive(): boolean
  }

  class Money <<ValueObject>> {
    + amount: BigDecimal
    + currency: String
    --
    + add(other: Money): Money
  }

  class UsageSummary <<ValueObject>> {
    + totalUsageHours: double
    + downtimeHours: double
    + averageDailyUsage: double
    + comparisonWithPreviousPct: double
  }

  class CostBreakdown <<ValueObject>> {
    + correctiveCost: Money
    + preventiveCost: Money
    + sparePartsCost: Money
    + totalCost: Money
    --
    + calculate(): CostBreakdown
  }

  class ROIMetrics <<ValueObject>> {
    + projectedEarnings: Money
    + totalCosts: Money
    + roiPercentage: double
    --
    + calculate(): ROIMetrics
  }

  ' ── Aggregate Root ──────────────────────────────────
  class ActivityReport <<AggregateRoot>> {
    + reportId: UUID
    + branchId: UUID
    + period: DateRange
    + summary: UsageSummary
    + generatedAt: LocalDateTime
    + requestedBy: UUID
    --
    + generate(): ActivityReportGeneratedEvent
    + export(format: String): byte[]
  }

  ' ── Entities ────────────────────────────────────────
  class CostReport <<Entity>> {
    + reportId: UUID
    + branchId: UUID
    + period: DateRange
    + breakdown: CostBreakdown
    --
    + generate(): CostReportGeneratedEvent
    + export(format: String): byte[]
  }

  class ROIReport <<Entity>> {
    + reportId: UUID
    + branchId: UUID
    + period: DateRange
    + metrics: ROIMetrics
    --
    + generate(): ROIReportGeneratedEvent
    + export(format: String): byte[]
  }

  ' ── Domain Events ───────────────────────────────────
  class ActivityReportGeneratedEvent <<DomainEvent>> {
    + reportId: UUID
    + branchId: UUID
    + period: DateRange
  }

  class CostReportGeneratedEvent <<DomainEvent>> {
    + reportId: UUID
    + totalCost: Money
  }

  class ROIReportGeneratedEvent <<DomainEvent>> {
    + reportId: UUID
    + roiPercentage: double
  }

  ' ── Repositories ────────────────────────────────────
  interface ActivityReportRepository <<Repository>> {
    + findByBranchIdAndPeriod(branchId: UUID, start: LocalDate, end: LocalDate): List<ActivityReport>
    + findLatestByBranchId(branchId: UUID): Optional<ActivityReport>
  }

  interface CostReportRepository <<Repository>> {
    + findByBranchIdAndPeriod(branchId: UUID, start: LocalDate, end: LocalDate): List<CostReport>
  }

  interface ROIReportRepository <<Repository>> {
    + findByBranchIdAndPeriod(branchId: UUID, start: LocalDate, end: LocalDate): List<ROIReport>
  }

  ' ── Application Service ─────────────────────────────
  class AnalyticsApplicationService <<ApplicationService>> {
    - activityRepo: ActivityReportRepository
    - costRepo: CostReportRepository
    - roiRepo: ROIReportRepository
    - publisher: DomainEventPublisher
    --
    + requestActivityAnalysis(cmd: RequestActivityCommand): ActivityReport
    + requestMaintenanceCostReport(cmd: RequestCostCommand): CostReport
    + requestROIReport(cmd: RequestROICommand): ROIReport
    + handleUsageSessionEnded(event: UsageSessionEndedEvent): void
    + handleMaintenanceCompleted(event: MaintenanceCompletedEvent): void
    + handleSparePartConsumed(event: SparePartConsumedEvent): void
  }

  ' ── Relaciones ──────────────────────────────────────
  ActivityReport *-- UsageSummary
  ActivityReport *-- DateRange
  CostReport *-- CostBreakdown
  CostReport *-- DateRange
  ROIReport *-- ROIMetrics
  ROIReport *-- DateRange
  CostBreakdown *-- Money
  ROIMetrics *-- Money

  ActivityReport ..> ActivityReportGeneratedEvent : publishes
  CostReport ..> CostReportGeneratedEvent : publishes
  ROIReport ..> ROIReportGeneratedEvent : publishes

  AnalyticsApplicationService --> ActivityReportRepository
  AnalyticsApplicationService --> CostReportRepository
  AnalyticsApplicationService --> ROIReportRepository
}

note top of AnalyticsApplicationService
  Consume: UsageSessionEndedEvent (desde Monitoring BC)
  Consume: MaintenanceCompletedEvent (desde Maintenance BC)
  Consume: SparePartConsumedEvent (desde Maintenance BC)
end note
@enduml
