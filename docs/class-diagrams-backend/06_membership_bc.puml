@startuml 06_MembershipBC
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam linetype ortho

title SpotTrack — BC 6: Membership\n(Tabla: gym_memberships · membership_plans · branch_accesses)

package "Membership BC" #F3E5F5 {

  ' ── Enums ──────────────────────────────────────────
  enum MembershipStatus {
    ACTIVE
    SUSPENDED
    CANCELLED
    EXPIRED
  }

  enum BranchAccessDecision {
    GRANTED
    DENIED
  }

  ' ── Value Objects ───────────────────────────────────
  class PlanDetails <<ValueObject>> {
    + planName: String
    + monthlyFee: Money
    + maxBranchesAllowed: int
    + allowsReservations: boolean
    + description: String
  }

  class DateRange <<ValueObject>> {
    + startDate: LocalDate
    + endDate: LocalDate
    --
    + isActive(): boolean
    + overlaps(other: DateRange): boolean
  }

  class Money <<ValueObject>> {
    + amount: BigDecimal
    + currency: String
    --
    + add(other: Money): Money
    + subtract(other: Money): Money
  }

  ' ── Aggregate Root ──────────────────────────────────
  class GymMembership <<AggregateRoot>> {
    + membershipId: UUID
    + clientId: UUID
    + period: DateRange
    + status: MembershipStatus
    --
    + activate(): GymMembershipActivatedEvent
    + renew(newPeriod: DateRange): GymMembershipRenewedEvent
    + suspend(): MembershipSuspendedEvent
    + cancel(): MembershipCancelledEvent
    + upgradePlan(plan: MembershipPlan): PlanUpgradedEvent
    + expire(): GymMembershipExpiredEvent
    + isActive(): boolean
  }

  ' ── Entities ────────────────────────────────────────
  class MembershipPlan <<Entity>> {
    + planId: UUID
    + details: PlanDetails
    --
    + isValid(): boolean
  }

  class BranchAccess <<Entity>> {
    + accessId: UUID
    + clientId: UUID
    + branchId: UUID
    + decision: BranchAccessDecision
    + evaluatedAt: LocalDateTime
    --
    + grantAccess(): BranchAccessGrantedEvent
    + denyAccess(): BranchAccessDeniedEvent
  }

  ' ── Domain Events ───────────────────────────────────
  class GymMembershipActivatedEvent <<DomainEvent>> {
    + membershipId: UUID
    + clientId: UUID
    + planId: UUID
  }

  class GymMembershipRenewedEvent <<DomainEvent>> {
    + membershipId: UUID
    + newPeriod: DateRange
  }

  class MembershipSuspendedEvent <<DomainEvent>> {
    + membershipId: UUID
    + clientId: UUID
  }

  class MembershipCancelledEvent <<DomainEvent>> {
    + membershipId: UUID
    + clientId: UUID
  }

  class PlanUpgradedEvent <<DomainEvent>> {
    + membershipId: UUID
    + previousPlanId: UUID
    + newPlanId: UUID
  }

  class GymMembershipExpiredEvent <<DomainEvent>> {
    + membershipId: UUID
    + clientId: UUID
  }

  class BranchAccessGrantedEvent <<DomainEvent>> {
    + clientId: UUID
    + branchId: UUID
  }

  class BranchAccessDeniedEvent <<DomainEvent>> {
    + clientId: UUID
    + branchId: UUID
    + reason: String
  }

  ' ── Repositories ────────────────────────────────────
  interface GymMembershipRepository <<Repository>> {
    + findByClientId(clientId: UUID): Optional<GymMembership>
    + findActiveByClientId(clientId: UUID): Optional<GymMembership>
    + findExpiring(start: LocalDate, end: LocalDate): List<GymMembership>
  }

  interface MembershipPlanRepository <<Repository>> {
    + findAll(): List<MembershipPlan>
    + findById(planId: UUID): Optional<MembershipPlan>
  }

  ' ── Application Service ─────────────────────────────
  class MembershipApplicationService <<ApplicationService>> {
    - membershipRepo: GymMembershipRepository
    - planRepo: MembershipPlanRepository
    - publisher: DomainEventPublisher
    --
    + activateMembership(cmd: ActivateMembershipCommand): GymMembership
    + renewMembership(cmd: RenewMembershipCommand): void
    + suspendMembership(cmd: SuspendMembershipCommand): void
    + cancelMembership(cmd: CancelMembershipCommand): void
    + upgradePlan(cmd: UpgradePlanCommand): void
    + grantBranchAccess(cmd: GrantBranchAccessCommand): BranchAccess
  }

  ' ── Relaciones ──────────────────────────────────────
  GymMembership *-- "1" MembershipPlan
  GymMembership *-- DateRange
  GymMembership -- MembershipStatus
  MembershipPlan *-- PlanDetails
  PlanDetails *-- Money
  BranchAccess -- BranchAccessDecision

  GymMembership ..> GymMembershipActivatedEvent : publishes
  GymMembership ..> GymMembershipRenewedEvent : publishes
  GymMembership ..> MembershipSuspendedEvent : publishes
  GymMembership ..> MembershipCancelledEvent : publishes
  GymMembership ..> PlanUpgradedEvent : publishes
  GymMembership ..> GymMembershipExpiredEvent : publishes
  BranchAccess ..> BranchAccessGrantedEvent : publishes
  BranchAccess ..> BranchAccessDeniedEvent : publishes

  MembershipApplicationService --> GymMembershipRepository
  MembershipApplicationService --> MembershipPlanRepository
}

note top of MembershipApplicationService
  Publica: MembershipSuspendedEvent → Reservation BC
  Publica: GymMembershipExpiredEvent → Reservation BC
end note
@enduml
