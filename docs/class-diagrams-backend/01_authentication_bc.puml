@startuml 01_AuthenticationBC
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam linetype ortho

title SpotTrack — BC 1: Authentication\n(Tabla: user_accounts · user_roles · user_sessions)

package "Authentication BC" #E3F2FD {

  ' ── Enums ──────────────────────────────────────────
  enum UserRoleType {
    ADMIN
    CLIENT
    TECHNICIAN
  }

  ' ── Value Objects ───────────────────────────────────
  class EmailAddress <<ValueObject>> {
    + value: String
    + validate(): boolean
  }

  class HashedPassword <<ValueObject>> {
    - hash: String
    + matches(rawPassword: String): boolean
  }

  class SessionToken <<ValueObject>> {
    + token: String
    + expiresAt: LocalDateTime
    + isExpired(): boolean
  }

  ' ── Aggregate Root ──────────────────────────────────
  class UserAccount <<AggregateRoot>> {
    + accountId: UUID
    + email: EmailAddress
    + fullName: String
    + password: HashedPassword
    + role: UserRoleType
    + isActive: boolean
    + failedLoginAttempts: int
    --
    + register(): UserRegisteredEvent
    + login(password: String): SessionToken
    + assignRole(role: UserRoleType): RoleAssignedEvent
    + deactivate(): AccountDeactivatedEvent
    + lockIfExceededAttempts(): void
    + resetPassword(newPwd: String): PasswordResetEvent
  }

  ' ── Entities ────────────────────────────────────────
  class UserSession <<Entity>> {
    + sessionId: UUID
    + accountId: UUID
    + token: SessionToken
    + ipAddress: String
    + createdAt: LocalDateTime
    --
    + logout(): UserLoggedOutEvent
  }

  ' ── Domain Events ───────────────────────────────────
  class UserRegisteredEvent <<DomainEvent>> {
    + accountId: UUID
    + email: String
    + role: UserRoleType
  }

  class RoleAssignedEvent <<DomainEvent>> {
    + accountId: UUID
    + newRole: UserRoleType
  }

  class AuthenticationFailedEvent <<DomainEvent>> {
    + accountId: UUID
    + failedAttempts: int
    + lockedAccount: boolean
  }

  class SessionTokenIssuedEvent <<DomainEvent>> {
    + accountId: UUID
    + sessionId: UUID
  }

  class AccountDeactivatedEvent <<DomainEvent>> {
    + accountId: UUID
  }

  class PasswordResetEvent <<DomainEvent>> {
    + accountId: UUID
  }

  ' ── Repository ──────────────────────────────────────
  interface UserAccountRepository <<Repository>> {
    + findByEmail(email: String): Optional<UserAccount>
    + findByRole(role: UserRoleType): List<UserAccount>
    + existsByEmail(email: String): boolean
  }

  ' ── Application Service ─────────────────────────────
  class AuthApplicationService <<ApplicationService>> {
    - userRepo: UserAccountRepository
    - publisher: DomainEventPublisher
    --
    + registerUser(cmd: RegisterUserCommand): UserAccount
    + login(cmd: LoginCommand): SessionToken
    + assignRole(cmd: AssignRoleCommand): void
    + logout(cmd: LogoutCommand): void
    + resetPassword(cmd: ResetPasswordCommand): void
    + deactivateAccount(cmd: DeactivateAccountCommand): void
  }

  ' ── Relaciones ──────────────────────────────────────
  UserAccount *-- EmailAddress
  UserAccount *-- HashedPassword
  UserAccount "1" *-- "*" UserSession
  UserAccount -- UserRoleType
  UserSession *-- SessionToken

  UserAccount ..> UserRegisteredEvent : publishes
  UserAccount ..> RoleAssignedEvent : publishes
  UserAccount ..> AuthenticationFailedEvent : publishes
  UserAccount ..> SessionTokenIssuedEvent : publishes
  UserAccount ..> AccountDeactivatedEvent : publishes
  UserAccount ..> PasswordResetEvent : publishes

  AuthApplicationService --> UserAccountRepository
}
@enduml
