@startuml 09_InterContextEventFlows
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageFontSize 13
skinparam packageFontStyle bold
skinparam ArrowColor #2C3E50
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F9A825

title SpotTrack — Flujos de Eventos entre Bounded Contexts\n(Comunicación asíncrona vía Message Bus)

' ── Bounded Contexts (cajas compactas) ─────────────
package "IoT Sensor Ingestion BC" #FFF8E1 {
  class IoTIngestionService as "IoTIngestionApplicationService" <<ApplicationService>>
}

package "Monitoring BC" #FFF3E0 {
  class MonitoringService as "MonitoringApplicationService" <<ApplicationService>>
}

package "Equipment BC" #E8F5E9 {
  class EquipmentService as "EquipmentApplicationService" <<ApplicationService>>
}

package "Reservation BC" #E0F2F1 {
  class ReservationService as "ReservationApplicationService" <<ApplicationService>>
}

package "Membership BC" #F3E5F5 {
  class MembershipService as "MembershipApplicationService" <<ApplicationService>>
}

package "Maintenance BC" #FFEBEE {
  class MaintenanceService as "MaintenanceApplicationService" <<ApplicationService>>
}

package "Analytics BC" #E8EAF6 {
  class AnalyticsService as "AnalyticsApplicationService" <<ApplicationService>>
}

package "Authentication BC" #E3F2FD {
  class AuthService as "AuthApplicationService" <<ApplicationService>>
}

' ── Flujos de eventos ──────────────────────────────

IoTIngestionService -[#FF8F00]-> MonitoringService : "<<event>>\nSensorDataCapturedEvent"

MonitoringService -[#F44336]-> MaintenanceService : "<<event>>\nMaintenanceRequestedEvent\n(anomalía detectada)"

MonitoringService -[#3F51B5]-> AnalyticsService : "<<event>>\nUsageSessionEndedEvent\n(datos de sesión)"

EquipmentService -[#4CAF50]-> ReservationService : "<<event>>\nEquipmentStatusUpdatedEvent\n(equipo disponible/OOS)"

EquipmentService -[#4CAF50]-> ReservationService : "<<event>>\nEquipmentDecommissionedEvent\n(cancela reservas activas)"

EquipmentService -[#3F51B5]-> AnalyticsService : "<<event>>\nSparePartConsumedEvent"

MembershipService -[#9C27B0]-> ReservationService : "<<event>>\nMembershipSuspendedEvent\n(cancela reservas del cliente)"

MembershipService -[#9C27B0]-> ReservationService : "<<event>>\nGymMembershipExpiredEvent"

MaintenanceService -[#F44336]-> EquipmentService : "<<event>>\nMaintenanceCompletedEvent\n(actualiza status a AVAILABLE)"

MaintenanceService -[#3F51B5]-> AnalyticsService : "<<event>>\nMaintenanceCompletedEvent\n(costos y datos)"

MaintenanceService -[#3F51B5]-> AnalyticsService : "<<event>>\nSparePartConsumedEvent"

' ── Notas ──────────────────────────────────────────
note bottom of MonitoringService
  Interpreta SensorDataCapturedEvent:
  • Cámara → OccupancyRecord
  • Movimiento → MonitoringSession
  • Peso → WeightSession / anomalía
end note

note bottom of ReservationService
  Reacciona a eventos de Equipment BC
  y Membership BC para mantener
  consistencia eventual
end note

note bottom of AnalyticsService
  Agrega datos de múltiples BCs
  para construir reportes de actividad,
  costos y ROI
end note

note right of AuthService
  Provee identidad a todos los BCs
  vía JWT (no mediante eventos,
  sino validación de token en
  cada request al API Gateway)
end note
@enduml
