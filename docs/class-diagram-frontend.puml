@startuml SpotTrack - Angular DDD Class Diagram

' ============================================================
' BOUNDED CONTEXT: Identity & Access Management
' ============================================================
package "iam.domain.model" {
  class User {
    + id: string
    + email: string
    + passwordHash: string
    + role: UserRole
    + constructor()
  }
  enum UserRole {
    ADMIN
    CLIENT
  }
}

package "iam.application" {
  class AuthStore {
    - currentUserSignal: Signal<User | null>
    - tokenSignal: Signal<string | null>
    - authApi: AuthApi
    - userAssembler: UserAssembler
    + currentUser: Signal<User | null>
    + token: Signal<string | null>
    + isAuthenticated: Signal<boolean>
    + login(email: string, password: string): void
    + logout(): void
    + register(email: string, password: string, role: UserRole): void
  }
}

package "iam.infrastructure" {
  class AuthApi {
    - http: HttpClient
    + login(email: string, password: string): Observable<AuthResponse>
    + register(email: string, password: string, role: UserRole): Observable<AuthResponse>
  }
  interface AuthResponse {
    + token: string
    + user: UserResource
  }
  interface UserResource {
    + id: string
    + email: string
    + role: string
  }
  class UserAssembler {
    + toEntityFromResource(resource: UserResource): User
  }
}

package "iam.presentation.components" {
  class LoginPage <<component>> {
    + email: string
    + password: string
    + authStore: AuthStore
    + onLogin(): void
  }
  class RegisterPage <<component>> {
    + email: string
    + password: string
    + role: UserRole
    + authStore: AuthStore
    + onRegister(): void
  }
}

' ============================================================
' BOUNDED CONTEXT: Profiles & Preferences Management
' ============================================================
package "profiles.domain.model" {
  class Profile {
    + id: string
    + userId: string
    + fullName: string
    + phone: string
    + preferredLanguage: string
    + accumulatedPoints: number
    + plan: SubscriptionPlan
    + notificationPreferences: NotificationPreferences
    + constructor()
  }
  class NotificationPreferences {
    + availabilityAlerts: boolean
    + scheduledMaintenance: boolean
    + rewardPoints: boolean
  }
  enum SubscriptionPlan {
    BASIC
    MID
    PLATINUM
  }
}

package "profiles.application" {
  class ProfileStore {
    - profileSignal: Signal<Profile | null>
    - profileApi: ProfileApi
    - profileAssembler: ProfileAssembler
    + profile: Signal<Profile | null>
    + loadProfile(userId: string): void
    + updateProfile(profile: Profile): void
    + changePassword(oldPassword: string, newPassword: string): void
    + updateNotificationPreferences(prefs: NotificationPreferences): void
  }
}

package "profiles.infrastructure" {
  class ProfileApi {
    - http: HttpClient
    + getProfile(userId: string): Observable<ProfileResource>
    + updateProfile(resource: ProfileResource): Observable<ProfileResource>
    + changePassword(userId: string, oldPwd: string, newPwd: string): Observable<void>
  }
  interface ProfileResource {
    + id: string
    + userId: string
    + fullName: string
    + phone: string
    + preferredLanguage: string
    + accumulatedPoints: number
    + plan: string
    + availabilityAlerts: boolean
    + scheduledMaintenance: boolean
    + rewardPoints: boolean
  }
  class ProfileAssembler {
    + toEntityFromResource(resource: ProfileResource): Profile
    + toResourceFromEntity(profile: Profile): ProfileResource
  }
}

package "profiles.presentation.components" {
  class ProfilePage <<component>> {
    + profileStore: ProfileStore
    + authStore: AuthStore
    + languageStore: LanguageStore
    + profile: Signal<Profile | null>
    + onSaveChanges(): void
    + onChangePassword(): void
    + onChangeLanguage(lang: string): void
    + onLogout(): void
  }
}

